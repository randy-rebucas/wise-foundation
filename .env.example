# Required
MONGODB_URI=mongodb://127.0.0.1:27017/glowish
AUTH_SECRET=replace-with-openssl-rand-hex-32
AUTH_URL=http://localhost:3000

# Optional — image uploads (Cloudinary in production)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional — local uploads (development)
# UPLOAD_DIR=
# UPLOAD_FOLDER_ROOT=

# Optional — maintenance & branding
# MAINTENANCE_MODE=true
# NEXT_PUBLIC_APP_NAME=Glowish

# Optional — PDF generation
# PDFKIT_FONT_PATH=
