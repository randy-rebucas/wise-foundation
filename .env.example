# Required
MONGODB_URI=mongodb://127.0.0.1:27017/glowish
AUTH_SECRET=replace-with-openssl-rand-hex-32
# Must match the URL in your browser (use 127.0.0.1 consistently if you open that host).
AUTH_URL=http://localhost:3000
# Aliases still supported: NEXTAUTH_SECRET, NEXTAUTH_URL

# Optional — image uploads (Cloudinary in production)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional — local uploads (development)
# UPLOAD_DIR=
# UPLOAD_FOLDER_ROOT=

# Optional — maintenance & branding
# MAINTENANCE_MODE=true
# NEXT_PUBLIC_APP_NAME=Glowish

# REQUIRED for production — canonical URLs, sitemap, and Open Graph (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-store.example.com

# Optional — PDF generation
# PDFKIT_FONT_PATH=

# Optional — PayMongo (PCI-compliant card / GCash at checkout)
# PAYMONGO_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_test_...

# Optional — Transactional email (SMTP, e.g. Hostinger)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@your-domain.com
# SMTP_PASS=your-mailbox-password
# EMAIL_FROM=Glowish <noreply@your-domain.com>

# Optional — Error monitoring (Sentry)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX   # server-only DSN if different
# SENTRY_AUTH_TOKEN=sntrys_...                        # CI/CD only — source map uploads
