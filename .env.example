# Required
MONGODB_URI=mongodb://127.0.0.1:27017/glowish
AUTH_SECRET=replace-with-openssl-rand-hex-32
AUTH_URL=http://localhost:3000

# Optional — image uploads (Cloudinary in production)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional — local uploads (defaults via next.config to <project>/public/uploads)
# UPLOAD_DIR=C:\path\to\wise\public\uploads

# Optional — maintenance & branding
# MAINTENANCE_MODE=true
# NEXT_PUBLIC_APP_NAME=Glowish

# Optional — PDF generation
# PDFKIT_FONT_PATH=

# Optional — PayMongo (PCI-compliant card / GCash at checkout)
# PAYMONGO_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_test_...

# Optional — J&T Express (Deliveries / purchase orders)
# JNT_API_ACCOUNT=your_eccompanyid
# JNT_PRIVATE_KEY=your_private_key
# JNT_CUSTOMER_CODE=your_customerid
# JNT_ORIGIN_NAME=Glowish Warehouse
# JNT_ORIGIN_PHONE=09171234567
# JNT_ORIGIN_ADDRESS=123 Street, Barangay
# JNT_ORIGIN_CITY=Metro Manila
# JNT_ORIGIN_AREA=NCR
# JNT_USE_SANDBOX=true
# JNT_API_BASE_URL=https://demoopenapi.jtexpress.ph
